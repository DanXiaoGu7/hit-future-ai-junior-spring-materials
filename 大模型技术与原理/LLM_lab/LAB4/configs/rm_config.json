{
  "model_name": "Qwen/Qwen2.5-0.5B-Instruct",
  "train_file": "data/processed/rm_train.jsonl",
  "eval_file": "data/processed/rm_eval.jsonl",
  "output_dir": "outputs/rm",
  "max_length": 768,
  "learning_rate": 2e-05,
  "num_train_epochs": 1,
  "per_device_train_batch_size": 1,
  "per_device_eval_batch_size": 1,
  "gradient_accumulation_steps": 8,
  "weight_decay": 0.01,
  "warmup_ratio": 0.03,
  "logging_steps": 10,
  "eval_steps": 50,
  "save_steps": 50,
  "save_total_limit": 2,
  "seed": 42,
  "fp16": false,
  "use_lora": false,
  "lora_r": 8,
  "lora_alpha": 16,
  "lora_dropout": 0.05,
  "target_modules": [
    "q_proj",
    "k_proj",
    "v_proj",
    "o_proj"
  ]
}
